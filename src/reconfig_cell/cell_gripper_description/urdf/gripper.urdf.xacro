<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cell_gripper">

  <!--
    Minimal 1-DOF parallel-jaw gripper.
    parent: link to attach to (typically tool0)
    prefix: joint/link name prefix matching the arm's tf_prefix
  -->
  <xacro:macro name="cell_gripper" params="parent prefix:=''">

    <!-- Fixed adapter: tool0 -> gripper base -->
    <joint name="${prefix}gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}gripper_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}gripper_base_link">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.06 0.06 0.04"/></geometry>
        <material name="gripper_grey"><color rgba="0.4 0.4 0.4 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.06 0.06 0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/>
      </inertial>
    </link>

    <!-- Left finger (prismatic, opens in -x direction) -->
    <joint name="${prefix}finger_left_joint" type="prismatic">
      <parent link="${prefix}gripper_base_link"/>
      <child  link="${prefix}finger_left_link"/>
      <origin xyz="-0.015 0 0.04" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.03" upper="0.0" effort="20" velocity="0.1"/>
    </joint>

    <link name="${prefix}finger_left_link">
      <visual>
        <origin xyz="-0.005 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.01 0.02 0.04"/></geometry>
        <material name="gripper_dark"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <origin xyz="-0.005 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.01 0.02 0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
      </inertial>
    </link>

    <!-- Right finger (prismatic, opens in +x direction) -->
    <joint name="${prefix}finger_right_joint" type="prismatic">
      <parent link="${prefix}gripper_base_link"/>
      <child  link="${prefix}finger_right_link"/>
      <origin xyz="0.015 0 0.04" rpy="0 0 0"/>
      <axis xyz="-1 0 0"/>
      <limit lower="-0.03" upper="0.0" effort="20" velocity="0.1"/>
    </joint>

    <link name="${prefix}finger_right_link">
      <visual>
        <origin xyz="0.005 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.01 0.02 0.04"/></geometry>
        <material name="gripper_dark"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <origin xyz="0.005 0 0.02" rpy="0 0 0"/>
        <geometry><box size="0.01 0.02 0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
      </inertial>
    </link>

    <!--
      Attach frame: where DetachableJoint binds parts.
      Sits between fingertips (0.04 base + 0.04 fingers = 0.08 m from tool0).
    -->
    <joint name="${prefix}gripper_attach_joint" type="fixed">
      <parent link="${prefix}gripper_base_link"/>
      <child  link="${prefix}gripper_attach_link"/>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}gripper_attach_link"/>

    <!--
      ros2_control for gripper joints.
      The hardware plugin (GazeboSimSystem) is declared in the parent xacro's
      gz_ros2_control plugin — this block just registers the joints.
    -->
    <ros2_control name="${prefix}gripper" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <!-- initial_value=-0.03 spawns the fingers OPEN (tips at x=+/-0.045) so the
           0.04 cube clears them on descent. The grasp is done by the cube's
           DetachableJoint (grasp-fix, spec §4), not finger friction, so the
           gripper is never actuated in Step 2 and simply stays at this open pose. -->
      <joint name="${prefix}finger_left_joint">
        <command_interface name="position">
          <param name="min">-0.03</param>
          <param name="max">0.0</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">-0.03</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${prefix}finger_right_joint">
        <command_interface name="position">
          <param name="min">-0.03</param>
          <param name="max">0.0</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">-0.03</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

  </xacro:macro>

</robot>
