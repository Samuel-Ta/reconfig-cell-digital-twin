#!/usr/bin/env python3
"""cell_generator — compile ONE declarative cell YAML into the three build artifacts.

    ros2 run cell_generator generate --config <config_N.yaml> [--out <dir>]

This is the contribution side of the paper (spec §7/§10): the single human-authored
YAML (cell_description/config_N.yaml) is the ONLY source of truth; world.sdf, the
MoveIt scene spec, and the task-with-derived-targets are GENERATED build products.
Reconfiguring (config_1 -> config_2) is a single append to the YAML + re-run of this
tool — no edits to the generated files, no code changes (INVARIANTS 4 & 5).

The generator loops over `stations` ONCE and emits, for cell <name>, into
<out>/<name>/:
  world.sdf   (§7 #1) one static <model> per fixture + one dynamic part per source
  scene.yaml  (§7 #2) flat list -> MoveIt CollisionObjects (fixtures only, as BOX)
  task.yaml   (§7 #3) abstract ops resolved to DERIVED top-down target poses

Generating config_1 reproduces the frozen reference_baseline (pick z=0.20, place
z=0.22), so the framework output is scope-matched to the rigid baseline.
"""
import argparse
import math
import os
import sys

import yaml

# ── constants of the CONSTANT robot/gripper (not per-config; live here, never in a
#    node — INVARIANT 3) ─────────────────────────────────────────────────────────
# tool0 -> gripper attach-frame distance for the minimal parallel-jaw gripper
# (cell_gripper_description). The derived tool0 target sits this far above the grasp
# point. Value matches the reference_baseline hand-derivation (…+ gripper_attach 0.08).
GRIPPER_ATTACH_Z = 0.08
# top-down grasp: tool0 +z -> world -z, quaternion (qx,qy,qz,qw) = (1,0,0,0)
TOPDOWN_QUAT = (1.0, 0.0, 0.0, 0.0)
# the box-fixture robot model the DetachableJoint binds the part to (INVARIANT 1:
# the part carries the grasp plugin; the robot description is untouched)
CHILD_MODEL = "ur5_with_gripper"

SOURCE_RGBA = "0.2 0.4 0.7 1"   # blue feeders
SINK_RGBA = "0.7 0.4 0.2 1"     # orange bins
PART_RGBA = "0.1 0.7 0.2 1"     # green cubes


def fmt(v):
    """Clean numeric formatting: drop float noise (0.12000000000000001 -> 0.12)."""
    if isinstance(v, float):
        return f"{v:.9g}"
    return str(v)


def rpy_to_quat(roll, pitch, yaw):
    cr, sr = math.cos(roll / 2), math.sin(roll / 2)
    cp, sp = math.cos(pitch / 2), math.sin(pitch / 2)
    cy, sy = math.cos(yaw / 2), math.sin(yaw / 2)
    return (
        sr * cp * cy - cr * sp * sy,   # qx
        cr * sp * cy + sr * cp * sy,   # qy
        cr * cp * sy - sr * sp * cy,   # qz
        cr * cp * cy + sr * sp * sy,   # qw
    )


def part_name(source_id):
    """source_1 -> cube_1 (deterministic, matches reference_baseline naming)."""
    return "cube_" + source_id.split("_")[-1]


# ── validation (refuse to build on violation — spec §7) ─────────────────────────
def validate(cell):
    stations = cell["stations"]
    ids = [s["id"] for s in stations]
    if len(ids) != len(set(ids)):
        sys.exit("INVALID: station ids are not unique")
    by_id = {s["id"]: s for s in stations}
    for s in stations:
        if s["type"] == "source" and s.get("part") is None:
            sys.exit(f"INVALID: source '{s['id']}' has no part")
        if s["type"] == "sink" and s.get("part") is not None:
            sys.exit(f"INVALID: sink '{s['id']}' must have part: null")
    for op in cell["task"]:
        ref = op.get("from") or op.get("to")
        if ref not in by_id:
            sys.exit(f"INVALID: task op references unknown station '{ref}'")
        if op["op"] == "pick" and by_id[ref]["type"] != "source":
            sys.exit(f"INVALID: pick must target a source, got '{ref}'")
        if op["op"] == "place" and by_id[ref]["type"] != "sink":
            sys.exit(f"INVALID: place must target a sink, got '{ref}'")
    return by_id


# ── derivation (spec §7 derived-target rule; the rigid baseline hardcodes these) ─
def fixture_top(station):
    """World z of the fixture top face (box sits base-on-ground at station.z)."""
    return station["pose"]["z"] + station["fixture"]["geometry"]["size"][2]


def pick_target_z(station):
    # tool0 = fixture_top + grasp.offset_z (grasp point above the fixture top)
    #         + gripper_attach (tool0 above the grasp point)
    return fixture_top(station) + station["part"]["grasp"]["offset_z"] + GRIPPER_ATTACH_Z


def place_target_z(sink, held_part):
    # the carried part rests on the sink top; tool0 sits a part-half + attach above it
    part_half = held_part["geometry"]["size"][2] / 2.0
    return fixture_top(sink) + part_half + GRIPPER_ATTACH_Z


# ── emitters ────────────────────────────────────────────────────────────────────
def emit_world(cell):
    L = ['<?xml version="1.0" ?>',
         f'<!-- GENERATED by cell_generator from {cell["name"]}.yaml — DO NOT EDIT.',
         '     Config-specific station fixtures + source parts only. The UR5+gripper',
         '     (INVARIANT 1) and the decorative backdrop are NOT here; the bringup',
         '     spawns/loads them separately. Parts carry the DetachableJoint grasp.',
         '     Reconfigure by editing the YAML and regenerating, never this file. -->',
         '<sdf version="1.6">',
         f'  <world name="{cell["name"]}">']
    for s in cell["stations"]:
        p = s["pose"]
        sx, sy, sz = s["fixture"]["geometry"]["size"]
        cz = p["z"] + sz / 2.0                       # box center (base-on-ground)
        rgba = SOURCE_RGBA if s["type"] == "source" else SINK_RGBA
        L += [f'    <model name="{s["id"]}">',
              '      <static>true</static>',
              f'      <pose>{fmt(p["x"])} {fmt(p["y"])} {fmt(cz)} {fmt(p["roll"])} {fmt(p["pitch"])} {fmt(p["yaw"])}</pose>',
              '      <link name="link">',
              f'        <collision name="collision"><geometry><box><size>{fmt(sx)} {fmt(sy)} {fmt(sz)}</size></box></geometry></collision>',
              f'        <visual name="visual"><geometry><box><size>{fmt(sx)} {fmt(sy)} {fmt(sz)}</size></box></geometry>',
              f'          <material><ambient>{rgba}</ambient><diffuse>{rgba}</diffuse></material></visual>',
              '      </link>',
              '    </model>']
    for s in cell["stations"]:
        if s["type"] != "source":
            continue
        p = s["pose"]
        px, py, pz = s["part"]["geometry"]["size"]
        cz = fixture_top(s) + pz / 2.0               # part rests on the fixture top
        name = part_name(s["id"])
        L += [f'    <model name="{name}">',
              f'      <pose>{fmt(p["x"])} {fmt(p["y"])} {fmt(cz)} 0 0 0</pose>',
              '      <link name="link">',
              '        <inertial><mass>0.05</mass>',
              '          <inertia><ixx>1.33e-5</ixx><iyy>1.33e-5</iyy><izz>1.33e-5</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>',
              f'        <collision name="collision"><geometry><box><size>{fmt(px)} {fmt(py)} {fmt(pz)}</size></box></geometry>',
              '          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>',
              f'        <visual name="visual"><geometry><box><size>{fmt(px)} {fmt(py)} {fmt(pz)}</size></box></geometry>',
              f'          <material><ambient>{PART_RGBA}</ambient><diffuse>{PART_RGBA}</diffuse></material></visual>',
              '      </link>',
              f'      <plugin filename="gz-sim-detachable-joint-system" name="gz::sim::systems::DetachableJoint">',
              '        <parent_link>link</parent_link>',
              f'        <child_model>{CHILD_MODEL}</child_model>',
              '        <child_link>wrist_3_link</child_link>',
              f'        <attach_topic>/{name}/attach</attach_topic>',
              f'        <detach_topic>/{name}/detach</detach_topic>',
              f'        <output_topic>/{name}/state</output_topic>',
              '        <suppress_child_warning>true</suppress_child_warning>',
              '      </plugin>',
              '    </model>']
    L += ['  </world>', '</sdf>', '']
    return "\n".join(L)


def emit_scene(cell):
    L = [f'# GENERATED by cell_generator from {cell["name"]}.yaml — DO NOT EDIT.',
         '# MoveIt planning-scene spec (§7 #2): each fixture -> one BOX CollisionObject',
         '# (pose = box CENTER in base_link). Parts are grasped, not avoided -> excluded.',
         f'frame_id: {cell["base_frame"]}',
         'collision_objects:']
    for s in cell["stations"]:
        p = s["pose"]
        sx, sy, sz = s["fixture"]["geometry"]["size"]
        cz = p["z"] + sz / 2.0
        qx, qy, qz, qw = rpy_to_quat(p["roll"], p["pitch"], p["yaw"])
        L += [f'  - id: {s["id"]}',
              f'    primitive: {{type: BOX, dimensions: [{sx}, {sy}, {sz}]}}',
              f'    pose: {{x: {p["x"]}, y: {p["y"]}, z: {cz}, '
              f'qx: {qx:.6g}, qy: {qy:.6g}, qz: {qz:.6g}, qw: {qw:.6g}}}']
    return "\n".join(L) + "\n"


def emit_task(cell, by_id):
    qx, qy, qz, qw = TOPDOWN_QUAT
    L = [f'# GENERATED by cell_generator from {cell["name"]}.yaml — DO NOT EDIT.',
         '# Task ops resolved to DERIVED top-down targets (§7 #3). The rigid baseline',
         '# hardcodes equivalents of these literals; here they are computed from module',
         '# data (station pose o fixture/part top-face o grasp/gripper offset).',
         f'frame_id: {cell["base_frame"]}',
         'ops:']
    held = None
    for op in cell["task"]:
        if op["op"] == "pick":
            s = by_id[op["from"]]
            z = pick_target_z(s)
            held = s["part"]
            name = part_name(s["id"])
            L += [f'  - {{op: pick,  station: {s["id"]}, part: {name},',
                  f'     target_pose: {{x: {s["pose"]["x"]}, y: {s["pose"]["y"]}, z: {z:.6g}, '
                  f'qx: {qx}, qy: {qy}, qz: {qz}, qw: {qw}}}}}']
        else:  # place
            s = by_id[op["to"]]
            z = place_target_z(s, held)
            L += [f'  - {{op: place, station: {s["id"]},',
                  f'     target_pose: {{x: {s["pose"]["x"]}, y: {s["pose"]["y"]}, z: {z:.6g}, '
                  f'qx: {qx}, qy: {qy}, qz: {qz}, qw: {qw}}}}}']
    return "\n".join(L) + "\n"


def main():
    ap = argparse.ArgumentParser(description="Compile a cell YAML into world/scene/task.")
    ap.add_argument("--config", required=True, help="path to config_N.yaml")
    ap.add_argument("--out", default=None,
                    help="output root dir (default: <config-dir>/generated)")
    args = ap.parse_args()

    with open(args.config) as f:
        doc = yaml.safe_load(f)
    # flatten: top-level `cell` map + the stations/task lists into one dict
    cell = {**doc["cell"], "stations": doc["stations"], "task": doc["task"]}

    by_id = validate(cell)

    out_root = args.out or os.path.join(os.path.dirname(os.path.abspath(args.config)), "generated")
    out_dir = os.path.join(out_root, cell["name"])
    os.makedirs(out_dir, exist_ok=True)

    artifacts = {
        "world.sdf": emit_world(cell),
        "scene.yaml": emit_scene(cell),
        "task.yaml": emit_task(cell, by_id),
    }
    for fname, content in artifacts.items():
        path = os.path.join(out_dir, fname)
        with open(path, "w") as f:
            f.write(content)
        print(f"  wrote {path}")
    print(f"[cell_generator] generated {cell['name']} "
          f"({len(cell['stations'])} stations, {len(cell['task'])} ops) -> {out_dir}")


if __name__ == "__main__":
    main()
