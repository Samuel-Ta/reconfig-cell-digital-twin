#!/usr/bin/env python3
"""cell_generator — compile ONE declarative conveyor-cell YAML into the build artifacts.

    ros2 run cell_generator generate --config <config_N.yaml> [--out <dir>]

Contribution side of the paper (spec §7/§10): the single authored YAML
(cell_description/config_N.yaml) is the ONLY source of truth. The MoveIt scene spec
and the task-with-derived-targets are GENERATED build products. The constant Intel
warehouse world (cell_arranged.world) and the UR5+RG2 robot are loaded by the bringup,
never generated (INVARIANT 1). Reconfiguring config_1 -> config_2 is a single append to
the YAML + a regenerate — no edits to generated files, no code (INVARIANTS 4 & 5).

Cell: a UR5+RG2 on a pedestal, surrounded by delivery conveyors. The generator loops
over `stations` (conveyors) once and emits, into <out>/<name>/:
  scene.yaml  (§7 #2) one BOX CollisionObject per conveyor (belt slab) in base_link
  task.yaml   (§7 #3) the relay ops resolved to DERIVED top-down grasp targets

DERIVATION (all geometry lives here, never in a node — INVARIANT 3):
  base(x,y)   = conveyor_world(x,y) - robot_mount(x,y)         # robot at yaw 0
  belt_target = base shifted INWARD toward the base by `inward` (reach the near edge)
  target z    = belt.top_z + part_half - robot_mount.z         # base_link frame
  spawn_pose  = belt_target back in WORLD + belt.top_z+part_half (cube rests on belt)
  orientation = top-down (tool0/TCP +z -> world -z), quat (1,0,0,0)
"""
import argparse
import math
import os
import sys

import yaml

TOPDOWN_QUAT = (1.0, 0.0, 0.0, 0.0)   # (qx,qy,qz,qw): tool frame +z -> world -z
CONVEYOR_RGBA = "0.5 0.5 0.55 1"
# belt-slab collision box footprint (length, width); height is the slab thickness
BELT_BOX_LEN, BELT_BOX_WID, BELT_BOX_THK = 1.0, 0.5, 0.10


def fmt(v):
    return f"{v:.9g}" if isinstance(v, float) else str(v)


def rpy_to_quat(roll, pitch, yaw):
    cr, sr = math.cos(roll / 2), math.sin(roll / 2)
    cp, sp = math.cos(pitch / 2), math.sin(pitch / 2)
    cy, sy = math.cos(yaw / 2), math.sin(yaw / 2)
    return (sr * cp * cy - cr * sp * sy, cr * sp * cy + sr * cp * sy,
            cr * cp * sy - sr * sp * cy, cr * cp * cy + sr * sp * sy)


# ── validation (refuse to build on violation — spec §7) ─────────────────────────
def validate(cell):
    stations = cell["stations"]
    ids = [s["id"] for s in stations]
    if len(ids) != len(set(ids)):
        sys.exit("INVALID: station ids are not unique")
    by_id = {s["id"]: s for s in stations}
    for op in cell["task"]:
        ref = op.get("from") or op.get("to")
        if ref not in by_id:
            sys.exit(f"INVALID: task op references unknown station '{ref}'")
    if not cell["task"] or cell["task"][0]["op"] != "pick":
        sys.exit("INVALID: task must start with a pick (the part is spawned there)")
    return by_id


# ── derivation ──────────────────────────────────────────────────────────────────
def base_xy(cell, station):
    """conveyor world (x,y) -> robot base_link (x,y) (robot mounted at yaw 0)."""
    m = cell["robot_mount"]
    return station["pose"]["x"] - m["x"], station["pose"]["y"] - m["y"]


def belt_target(cell, station):
    """base (x,y) shifted INWARD toward the base origin to the belt's near edge."""
    bx, by = base_xy(cell, station)
    r = math.hypot(bx, by)
    if r < 1e-6:
        return bx, by
    inward = cell["belt"]["inward"]
    return bx - inward * bx / r, by - inward * by / r


def part_half(cell):
    return cell["part"]["geometry"]["size"][2] / 2.0


def grasp_z(cell):
    """tool/TCP target z in base_link: belt top + part half, lowered by the mount height."""
    return cell["belt"]["top_z"] + part_half(cell) - cell["robot_mount"]["z"]


def spawn_world(cell, station):
    """WORLD pose where the cube rests on this conveyor's belt (for the first pick)."""
    m = cell["robot_mount"]
    sx, sy = belt_target(cell, station)
    return sx + m["x"], sy + m["y"], cell["belt"]["top_z"] + part_half(cell)


# ── emitters ────────────────────────────────────────────────────────────────────
def emit_scene(cell, by_id):
    L = [f'# GENERATED by cell_generator from {cell["name"]}.yaml — DO NOT EDIT.',
         '# MoveIt planning-scene spec (§7 #2): each conveyor -> one BOX CollisionObject',
         '# (a belt slab at the belt top, in base_link). Used by cell_scene_manager.',
         f'frame_id: {cell["base_frame"]}',
         'collision_objects:']
    mz = cell["robot_mount"]["z"]
    # one slab per conveyor that the task actually uses (config-agnostic: the set comes
    # from the task ops, so config_1 omits the unused conveyor_3)
    used = []
    for op in cell["task"]:
        sid = op.get("from") or op.get("to")
        if sid not in used:
            used.append(sid)
    for sid in used:
        s = by_id[sid]
        bx, by = base_xy(cell, s)
        cz = cell["belt"]["top_z"] - BELT_BOX_THK / 2.0 - mz      # slab top at belt top
        qx, qy, qz, qw = rpy_to_quat(0, 0, s["pose"]["yaw"])
        L += [f'  - id: {sid}',
              f'    primitive: {{type: BOX, dimensions: [{BELT_BOX_LEN}, {BELT_BOX_WID}, {BELT_BOX_THK}]}}',
              f'    pose: {{x: {fmt(bx)}, y: {fmt(by)}, z: {fmt(cz)}, '
              f'qx: {qx:.6g}, qy: {qy:.6g}, qz: {qz:.6g}, qw: {qw:.6g}}}']
    return "\n".join(L) + "\n"


def emit_task(cell, by_id):
    qx, qy, qz, qw = TOPDOWN_QUAT
    z = grasp_z(cell)
    part = cell["part"]["name"]
    L = [f'# GENERATED by cell_generator from {cell["name"]}.yaml — DO NOT EDIT.',
         '# Relay task resolved to DERIVED top-down grasp targets (§7 #3), base_link frame.',
         '# The box is carried the whole way: spawn_pose (WORLD) appears on the FIRST pick',
         '# only; later picks re-grasp the carried cube. No pose literals in the executor.',
         f'frame_id: {cell["base_frame"]}',
         f'part: {part}',
         'ops:']
    first_pick_done = False
    for op in cell["task"]:
        if op["op"] == "pick":
            s = by_id[op["from"]]
            bx, by = belt_target(cell, s)
            line = (f'  - {{op: pick,  station: {s["id"]}, '
                    f'target_pose: {{x: {fmt(bx)}, y: {fmt(by)}, z: {fmt(z)}, '
                    f'qx: {qx}, qy: {qy}, qz: {qz}, qw: {qw}}}')
            if not first_pick_done:
                wx, wy, wz = spawn_world(cell, s)
                line += (f',\n     spawn_pose: {{x: {fmt(wx)}, y: {fmt(wy)}, z: {fmt(wz)}}}}}')
                first_pick_done = True
            else:
                line += '}'
            L.append(line)
        else:  # place
            s = by_id[op["to"]]
            bx, by = belt_target(cell, s)
            L.append(f'  - {{op: place, station: {s["id"]}, '
                     f'target_pose: {{x: {fmt(bx)}, y: {fmt(by)}, z: {fmt(z)}, '
                     f'qx: {qx}, qy: {qy}, qz: {qz}, qw: {qw}}}}}')
    return "\n".join(L) + "\n"


def main():
    ap = argparse.ArgumentParser(description="Compile a conveyor-cell YAML into scene/task.")
    ap.add_argument("--config", required=True, help="path to config_N.yaml")
    ap.add_argument("--out", default=None, help="output root dir (default: <config-dir>/generated)")
    args = ap.parse_args()

    with open(args.config) as f:
        doc = yaml.safe_load(f)
    cell = {**doc["cell"], "robot_mount": doc["robot_mount"], "belt": doc["belt"],
            "part": doc["part"], "stations": doc["stations"], "task": doc["task"]}

    by_id = validate(cell)

    out_root = args.out or os.path.join(os.path.dirname(os.path.abspath(args.config)), "generated")
    out_dir = os.path.join(out_root, cell["name"])
    os.makedirs(out_dir, exist_ok=True)

    for fname, content in (("scene.yaml", emit_scene(cell, by_id)),
                           ("task.yaml", emit_task(cell, by_id))):
        with open(os.path.join(out_dir, fname), "w") as f:
            f.write(content)
        print(f"  wrote {os.path.join(out_dir, fname)}")
    print(f"[cell_generator] generated {cell['name']} "
          f"({len(cell['stations'])} conveyors, {len(cell['task'])} ops) -> {out_dir}")


if __name__ == "__main__":
    main()
