#!/usr/bin/env python3
"""synthesize — Rung 1 entry point: propose -> is_valid() -> emit first valid config.

    ros2 launch cell_synth synth.launch.py exe:=synthesize \
        k:=5 n_stations:=3 seed:=7 out_dir:=<dir>

Loops constrained sampling through the headless oracle and emits K fully-valid cell YAMLs
in the existing schema (drop-in to cell_generator). Logs per accepted config: seed,
attempts, cumulative hit-rate, wall time, and the joint-travel surrogate (logged, NOT
optimized — Rung 1 finds valid configs only). Writes a CSV summary next to the configs.
"""
import csv
import os
import sys
import time

import rclpy
import yaml
from ament_index_python.packages import get_package_share_directory

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import synth_core as core  # noqa: E402

from moveit.planning import MoveItPy  # noqa: E402


def _arg(name, default):
    """Read a value from a ROS-style argv (`name:=value`) or `--name value`."""
    pref = f"{name}:="
    for a in sys.argv[1:]:
        if a.startswith(pref):
            return a[len(pref):]
    if f"--{name}" in sys.argv:
        i = sys.argv.index(f"--{name}")
        if i + 1 < len(sys.argv):
            return sys.argv[i + 1]
    return default


def main():
    k = int(_arg("k", "5"))
    n_stations = int(_arg("n_stations", "3"))
    seed = int(_arg("seed", "1"))
    max_attempts = int(_arg("max_attempts", "800"))
    quality = _arg("quality", "1") not in ("0", "off", "false")
    min_gap = float(_arg("min_gap", "0.18"))
    min_ang = float(_arg("min_ang", "50"))
    base_config = _arg("base_config", "config_1") or "config_1"
    out_dir = _arg("out_dir", "") or os.path.join(os.path.expanduser("~"), "reconfig_ws",
                                                  "src", "reconfig_cell", "synth_out")
    out_dir = os.path.abspath(out_dir)
    os.makedirs(out_dir, exist_ok=True)

    # base_config may be a NAME in cell_description, or a direct path to a base YAML
    # (use a path to synthesize around a custom robot_mount, e.g. a hand-placed robot)
    if os.path.isfile(base_config):
        base_path = base_config
    elif os.path.isfile(base_config + ".yaml"):
        base_path = base_config + ".yaml"
    else:
        base_path = os.path.join(get_package_share_directory("cell_description"),
                                 f"{base_config}.yaml")
    with open(base_path) as f:
        base_doc = yaml.safe_load(f)

    rclpy.init()
    t_boot = time.time()
    moveit = MoveItPy(node_name="cell_synth")
    oracle = core.Oracle(moveit)
    proposer = core.Proposer(base_doc, seed=seed)
    print(f"[synth] headless oracle up in {time.time()-t_boot:.1f}s; "
          f"target K={k} valid configs, n_stations={n_stations}, seed={seed}, "
          f"base={base_config}, out={out_dir}")

    rows = []
    total_attempts = 0
    run_t0 = time.time()
    for i in range(k):
        attempts = 0
        accepted = None
        t = time.time()
        while attempts < max_attempts:
            attempts += 1
            total_attempts += 1
            doc = proposer.sample(n_stations)
            valid, reason = oracle.is_valid(doc, f"synth_{seed}_{i}")
            if not valid:
                continue
            if quality:                              # aesthetic filter (gaps/spread/facing)
                ok_q, reason = core.layout_quality(doc, f"synth_{seed}_{i}",
                                                   min_gap=min_gap, min_ang_deg=min_ang)
                if not ok_q:
                    continue
            accepted = doc
            break
        dt = time.time() - t
        if accepted is None:
            print(f"[synth] config {i}: NO valid config in {attempts} attempts "
                  f"(last reason {reason}); giving up this slot")
            rows.append(dict(idx=i, seed=seed, n_stations=n_stations, attempts=attempts,
                             accepted=0, wall_s=round(dt, 3), surrogate="", path="",
                             last_reason=reason))
            continue
        surrogate = oracle.joint_travel_surrogate(accepted, f"synth_{seed}_{i}")
        fname = f"synth_s{seed}_n{n_stations}_{i}.yaml"
        path = os.path.join(out_dir, fname)
        prov = (f"seed={seed} idx={i} attempts={attempts} n_stations={n_stations} "
                f"base={base_config} surrogate={surrogate}")
        core.write_config_yaml(accepted, path, prov)
        hit = (i + 1) / total_attempts
        print(f"[synth] config {i}: VALID after {attempts} attempt(s), {dt:.2f}s, "
              f"surrogate={surrogate if surrogate is None else round(surrogate,4)} -> {fname}")
        rows.append(dict(idx=i, seed=seed, n_stations=n_stations, attempts=attempts,
                         accepted=1, wall_s=round(dt, 3),
                         surrogate=("" if surrogate is None else round(surrogate, 6)),
                         path=fname, last_reason="valid"))

    wall = time.time() - run_t0
    n_ok = sum(r["accepted"] for r in rows)
    hit_rate = n_ok / total_attempts if total_attempts else 0.0
    summary = os.path.join(out_dir, f"synth_summary_s{seed}_n{n_stations}.csv")
    with open(summary, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=["idx", "seed", "n_stations", "attempts",
                                          "accepted", "wall_s", "surrogate", "path",
                                          "last_reason"])
        w.writeheader()
        w.writerows(rows)

    print("=" * 64)
    print(f"  RUNG 1 SYNTHESIS — seed {seed}, n_stations {n_stations}")
    print(f"  valid configs emitted : {n_ok}/{k}")
    print(f"  total attempts        : {total_attempts}")
    print(f"  valid-hit rate        : {n_ok}/{total_attempts} = {hit_rate:.3f}")
    print(f"  wall time             : {wall:.2f}s  ({wall/max(total_attempts,1)*1000:.1f} ms/attempt)")
    print(f"  summary CSV           : {summary}")
    print("=" * 64)
    core.GUARD._exit(0 if n_ok == k else 1)


if __name__ == "__main__":
    sys.exit(main())
