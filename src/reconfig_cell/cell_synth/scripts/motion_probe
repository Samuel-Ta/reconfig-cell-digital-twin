#!/usr/bin/env python3
"""motion_probe — surrogate vs REAL planner motion time (Rung 3 validation, attempt 2).

HEADLESS: for each config, plan the relay joint-to-joint between the SAME canonical (elbow-up)
waypoints the surrogate uses, with the real RRTConnect planner + the config's belt collisions
in the scene, and measure the planned TRAJECTORY DURATION (sim-time motion). Averaged over
N_PLANS to handle OMPL's path randomness (the OMPL seed is not settable via MoveIt params).
This strips the two documented noise sources: gz wall-clock/real-time-factor noise and the
~130 s config-independent reset overhead. No gz execution -> no hangs.

    ros2 launch cell_synth synth.launch.py exe:=motion_probe valset:=<dir> n_plans:=12

Outputs <valset>/motion.csv (label, surrogate, motion_mean_s, motion_std, n_plans) for the
correlation, and a stability check (one config planned N times: per-plan spread vs mean).
"""
import csv
import glob
import os
import statistics
import sys

import rclpy
import yaml
from ament_index_python.packages import get_package_share_directory

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import synth_core as core  # noqa: E402

from moveit.planning import MoveItPy, PlanRequestParameters  # noqa: E402
from moveit.core.robot_state import RobotState  # noqa: E402


def _arg(name, default):
    for a in sys.argv[1:]:
        if a.startswith(f"{name}:="):
            return a[len(name) + 2:]
    return default


def _traj_dur(plan_result):
    jt = plan_result.trajectory.get_robot_trajectory_msg().joint_trajectory
    if not jt.points:
        return None
    t = jt.points[-1].time_from_start
    return t.sec + t.nanosec * 1e-9


class Mover:
    def __init__(self, moveit, oracle, n_ik=40):
        self.moveit = moveit
        self.o = oracle
        self.model = oracle.model
        self.pc = moveit.get_planning_component(core.GUARD.GROUP)
        self.psm = moveit.get_planning_scene_monitor()
        self.n_ik = n_ik
        self.seedbank = oracle._seedbank(n_ik, 20240615)
        self.group_joints = ["shoulder_pan_joint", "shoulder_lift_joint", "elbow_joint",
                             "wrist_1_joint", "wrist_2_joint", "wrist_3_joint"]

    def _cos(self, scene_spec):
        return [core.GUARD.build_collision_object(e, self.o.frame)
                for e in scene_spec.get("collision_objects", [])]

    def _apply_scene(self, cos, exclude_ids=()):
        """Apply every belt EXCEPT those in `exclude_ids` to BOTH the planner scene and the
        oracle's IK-collision scene. A transfer segment A->B leaves fixture A and approaches
        fixture B, so BOTH endpoint belts are excluded (approaching/leaving a fixture is
        required, not a collision — is_valid's rule, applied to both ends); every OTHER belt
        stays in and must be avoided."""
        ex = set(exclude_ids)
        with self.psm.read_write() as scene:         # for the PLANNER
            scene.remove_all_collision_objects()
            for co in cos:
                if co.id not in ex:
                    scene.apply_collision_object(co)
            scene.current_state.update()
        self.o.scene.remove_all_collision_objects()   # for the IK collision check
        for co in cos:
            if co.id not in ex:
                self.o.scene.apply_collision_object(co)
        self.o.scene.current_state.update()

    def motion_time(self, task_spec, scene_spec, params):
        """Total planned trajectory duration over the (TSP-ordered) relay, planned JOINT-to-
        JOINT. Per op: exclude the target's own belt (is_valid's rule), pick the collision-free
        IK goal in the SAME kinematic branch as the previous station (continuity -> no fake
        elbow-flip spikes), and plan with the OPTIMIZING planner (RRTstar) so path length is
        minimized and tracks the minimal-joint-travel surrogate."""
        dbg = os.environ.get("DEBUG_PROBE")
        cos = self._cos(scene_spec)
        prev_q = list(core.GUARD.UP_SEED)
        prev_sta = None
        total = 0.0
        for i, op in enumerate(task_spec.get("ops", [])):
            self._apply_scene(cos, exclude_ids=(prev_sta, op["station"]))
            goal_q = self.o.solve_ik_continuous(
                core._to_pose(op["target_pose"]), prev_q, self.o.scene, self.seedbank)
            if goal_q is None:
                if dbg:
                    print(f"[dbg] op{i} sta={op['station']}: solve_ik_continuous -> None")
                return None
            start = RobotState(self.model)
            start.set_joint_group_positions(core.GUARD.GROUP, prev_q); start.update()
            goal = RobotState(self.model)
            goal.set_joint_group_positions(core.GUARD.GROUP, goal_q); goal.update()
            self.pc.set_start_state(robot_state=start)
            self.pc.set_goal_state(robot_state=goal)
            r = self.pc.plan(single_plan_parameters=params)
            if r is None or r.trajectory is None or r.error_code.val != 1:
                if dbg:
                    ec = None if r is None else r.error_code.val
                    print(f"[dbg] op{i} sta={op['station']}: plan failed error_code={ec}")
                return None
            d = _traj_dur(r)
            if d is None:
                return None
            total += d
            prev_q = goal_q                            # continuity: next start = this goal
            prev_sta = op["station"]
        return total


def main():
    n_plans = int(_arg("n_plans", "12"))
    valset_dir = os.path.abspath(_arg("valset", "") or
                  os.path.expanduser("~/reconfig_ws/src/reconfig_cell/val_hb"))
    sur = {r["label"]: r for r in csv.DictReader(open(os.path.join(valset_dir, "valset_surrogate.csv")))}

    rclpy.init()
    moveit = MoveItPy(node_name="cell_synth")
    oracle = core.Oracle(moveit)
    mover = Mover(moveit, oracle)

    planner = _arg("planner", "RRTstar")     # OPTIMIZING planner
    params = PlanRequestParameters(moveit, "ompl")
    params.planner_id = planner
    params.planning_pipeline = "ompl"
    params.planning_attempts = 1           # RRTstar optimizes within one run (over planning_time)
    params.planning_time = float(_arg("planning_time", "10.0"))
    params.max_velocity_scaling_factor = 0.3
    params.max_acceleration_scaling_factor = 0.3
    print(f"[probe] planner={planner} planning_time={params.planning_time}s n_plans={n_plans}")

    def prep(doc):
        """Fix the visit order by brute-force TSP, then realize -> (task_spec, scene_spec,
        surrogate-on-this-order). Surrogate and real motion use the SAME (TSP) order."""
        order = oracle.tsp_order(doc)
        d2 = dict(doc); d2["task"] = core.relay_from_order(order)
        scene_spec, task_spec, _ = core.realize(core.make_cell(d2))
        s = oracle.surrogate_det(d2, task_spec=task_spec)
        return task_spec, scene_spec, s, order

    # STABILITY CHECK first: one config planned N times -> per-plan spread vs mean
    first = sorted(sur)[0]
    ts0, sc0, s0, ord0 = prep(yaml.safe_load(open(os.path.join(valset_dir, sur[first]["config"]))))
    vals0 = [mover.motion_time(ts0, sc0, params) for _ in range(n_plans)]
    vals0 = [v for v in vals0 if v is not None]
    if vals0:
        sp = (max(vals0) - min(vals0)) / statistics.mean(vals0) * 100
        print(f"[probe] STABILITY ({first}, {len(vals0)}/{n_plans} plans): mean {statistics.mean(vals0):.2f}s "
              f"std {statistics.pstdev(vals0):.2f}s per-plan spread {sp:.0f}%")

    rows = []
    for label in sorted(sur):
        doc = yaml.safe_load(open(os.path.join(valset_dir, sur[label]["config"])))
        task_spec, scene_spec, s_tsp, order = prep(doc)
        vals = [mover.motion_time(task_spec, scene_spec, params) for _ in range(n_plans)]
        vals = [v for v in vals if v is not None]
        if not vals:
            print(f"[probe] {label}: no plan succeeded"); continue
        rows.append(dict(label=label, surrogate=round(s_tsp, 4),
                         motion_mean=round(statistics.mean(vals), 3),
                         motion_min=round(min(vals), 3),
                         motion_median=round(statistics.median(vals), 3),
                         motion_std=round(statistics.pstdev(vals), 3), n_plans=len(vals)))
        print(f"[probe] {label}: surrogate(TSP) {s_tsp:.3f}  motion mean {rows[-1]['motion_mean']:.2f}s "
              f"min {rows[-1]['motion_min']:.2f}s med {rows[-1]['motion_median']:.2f}s "
              f"+/-{rows[-1]['motion_std']:.2f} (n={len(vals)})")

    out = os.path.join(valset_dir, "motion.csv")
    with open(out, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=["label", "surrogate", "motion_mean", "motion_min",
                                          "motion_median", "motion_std", "n_plans"])
        w.writeheader(); w.writerows(rows)
    print(f"[probe] wrote {out} ({len(rows)} configs)")
    core.GUARD._exit(0)


if __name__ == "__main__":
    main()
